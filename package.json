{
  "name": "ubearitz-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "build": "npm run prisma:generate && tsc",
    "start": "node dist/index.js",
    "db:up": "docker compose up -d mariadb",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:init": "npm run db:up && npm run prisma:generate && npm run db:migrate:deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "test:unit": "vitest run src/services/__tests__",
    "test:integration:prepare": "dotenv -e .env.test -- node scripts/prepare-test-db.mjs && dotenv -e .env.test -- prisma migrate deploy",
    "test:integration": "npm run test:integration:prepare && dotenv -e .env.test -- vitest run __tests__/integration",
    "test": "npm run prisma:generate && npm run test:unit && npm run test:integration",
    "test:coverage": "npm run prisma:generate && npm run test:integration:prepare && dotenv -e .env.test -- vitest run --coverage"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/websocket": "^11.2.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sinclair/typebox": "^0.34.41",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.0.1",
    "graphql": "^16.13.2",
    "mariadb": "^3.5.2",
    "mercurius": "^16.9.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@fastify/static": "^9.1.3",
    "@hono/node-server": "^1.19.14",
    "fast-jwt": "^6.2.3",
    "hono": "^4.12.15"
  }
}
